# Copy this file to .env and fill in your own values before running
# scripts/deploy.sh or docker-compose.prod.yml.
#
#   cp .env.example .env

# Your Docker Hub username/namespace that the images were published under
# by the container-ci-cd workflow.
DOCKERHUB_USERNAME=

# Prefix used for the image repository names, e.g.
# <DOCKERHUB_USERNAME>/<APP_NAME>-service-a
# Must match the GitHub repo name (what container-ci-cd.yml uses via
# github.event.repository.name) so published image names line up with what
# scripts/deploy.sh and docker-compose.prod.yml pull.
APP_NAME=devops-satellite-telemetry

# Image tag to deploy. Produced by CI as sha-<7-char-commit-sha>.
# scripts/deploy.sh requires this be passed as its argument (e.g. sha-a1b2c3d);
# never use "latest" for deployment.
IMAGE_TAG=
